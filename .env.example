# OpsPilot Configuration
OPSPILOT_APP_NAME=OpsPilot
OPSPILOT_DEBUG=false
OPSPILOT_SECRET_KEY=change-me-to-a-random-string
OPSPILOT_DATABASE_URL=sqlite+aiosqlite:///./data/opspilot.db

# Docker
OPSPILOT_DOCKER_NETWORK=opspilot-network
OPSPILOT_DEPLOY_BASE_PATH=./data/deployments

# AI Configuration (在 Web 界面的「模型配置」中添加具体配置)
# 支持 provider: openai, anthropic, ollama (自建)
OPSPILOT_OLLAMA_BASE_URL=http://localhost:11434
OPSPILOT_OLLAMA_MODEL=gpt-4o

# CORS
OPSPILOT_CORS_ORIGINS=["http://localhost","http://localhost:80"]

# Logging
OPSPILOT_LOG_LEVEL=INFO
